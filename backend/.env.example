# Server Configuration
PORT=8080
ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Dev user seed — must match frontend VITE_DEV_USER_ID so the planner's
# POST /bookings finds the seeded user when the auth guard is bypassed.
DEV_USER_ID=usr_dev_001

# Firebase Admin SDK — required when DB_DRIVER=firestore or when
# DEV_USER_ID is unset (i.e. real token verification is on). The value is
# the entire service-account JSON pasted inline. The file is gitignored;
# copy its content into the env var on your machine:
#   FIREBASE_CREDENTIALS_JSON='{"type":"service_account",...}'
FIREBASE_CREDENTIALS_JSON=

# Store driver. "firestore" persists users + bookings in Firebase; "memory"
# uses the in-process MemoryStore (data wiped on restart — dev/demo only).
DB_DRIVER=firestore

# Google Cloud APIs — single key covers Routes, Places, and Geocoding
# (Maps JS API tile rendering uses a separate VITE_GOOGLE_MAPS_API_KEY in the frontend).
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Vertex AI / Gemini — leave VERTEX_PROJECT_ID empty to disable the
# batched ranker and fall back to the templated scorer.
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_AGENT_MODEL=gemini-2.5-flash-lite

# Genkit Configuration
GENKIT_MODEL=google-gemini-pro
GENKIT_EVAL_MODEL=google-gemini-1.5-pro

# Logging
LOG_LEVEL=debug

# Feature Flags
USE_MOCK_PAYMENT=true
USE_MOCK_TRANSPORT_APIS=true
USE_HARDCODED_CARBON_DATA=false

# Peak Hours Configuration (24-hour format, comma-separated)
PEAK_HOURS_START_1=07
PEAK_HOURS_END_1=09
PEAK_HOURS_START_2=12
PEAK_HOURS_END_2=13
PEAK_HOURS_START_3=17
PEAK_HOURS_END_3=19

# Carbon Data Baseline (grams CO2 per km)
BASELINE_CARBON_EV_TAXI=120
BASELINE_CARBON_LRT=80
BASELINE_CARBON_MRT=80
BASELINE_CARBON_BUS=100
BASELINE_CARBON_PRIVATE_CAR=200